<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_layout_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/widget_bg"
    android:orientation="vertical"
    android:padding="12dp">

    <!-- Premium Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:paddingBottom="8dp"
        android:orientation="horizontal">
        
        <!-- Glowing Pulse Indicator (Using ImageView instead of prohibited generic View for RemoteViews safety!) -->
        <ImageView
            android:layout_width="6dp"
            android:layout_height="6dp"
            android:layout_marginEnd="6dp"
            android:src="@android:drawable/presence_online" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="FREEFORM BETA"
            android:textColor="#E0E0E0"
            android:textSize="10sp"
            android:textStyle="bold"
            android:letterSpacing="0.1" />

        <ImageView
            android:id="@+id/widget_refresh"
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:src="@android:drawable/stat_notify_sync"
            android:padding="2dp"
            android:alpha="0.8" />
    </LinearLayout>

    <ListView
        android:id="@+id/widget_list"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:divider="@null"
        android:dividerHeight="0dp"
        android:scrollbars="none" />
        
    <Button
        android:id="@+id/widget__rescueall"
        android:layout_width="match_parent"
        android:layout_height="32dp"
        android:background="@drawable/widget_button_rescue"
        android:text="🛠️ Force Rescue All Tasks"
        android:textColor="#E0E0E0"
        android:textSize="10sp"
        android:textStyle="bold"
        android:layout_marginTop="6dp" />

</LinearLayout>
