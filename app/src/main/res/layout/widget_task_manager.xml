<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_task_manager_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/widget_bg"
    android:orientation="vertical"
    android:padding="12dp">

    <!-- Premium Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:paddingBottom="8dp"
        android:orientation="horizontal">
        
        <!-- Glowing Pulse Indicator -->
        <ImageView
            android:layout_width="6dp"
            android:layout_height="6dp"
            android:layout_marginEnd="6dp"
            android:src="@android:drawable/presence_online" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="TASK MONITOR"
            android:textColor="#E0E0E0"
            android:textSize="10sp"
            android:textStyle="bold"
            android:letterSpacing="0.1" />

        <!-- Refresh Button -->
        <ImageView
            android:id="@+id/widget_task_refresh"
            android:layout_width="22dp"
            android:layout_height="22dp"
            android:src="@android:drawable/stat_notify_sync"
            android:padding="2dp"
            android:alpha="0.8"
            android:layout_marginEnd="8dp"
            android:background="?android:attr/selectableItemBackgroundBorderless"
            android:contentDescription="Refresh List" />

        <!-- Open Console Companion Button -->
        <ImageView
            android:id="@+id/widget_task_btn_open_app"
            android:layout_width="22dp"
            android:layout_height="22dp"
            android:src="@android:drawable/ic_menu_directions"
            android:padding="2dp"
            android:alpha="0.8"
            android:background="?android:attr/selectableItemBackgroundBorderless"
            android:contentDescription="Open Console App" />
    </LinearLayout>

    <!-- Task ListView -->
    <ListView
        android:id="@+id/widget_task_list"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:divider="@null"
        android:dividerHeight="0dp"
        android:scrollbars="none" />

</LinearLayout>
