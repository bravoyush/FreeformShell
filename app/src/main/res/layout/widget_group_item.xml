<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_item_root"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="10dp"
    android:background="@drawable/widget_item_bg"
    android:layout_marginTop="4dp"
    android:layout_marginBottom="4dp">

    <!-- Header Row -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical">
        
        <TextView
            android:id="@+id/group_title"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="PHONE WORKSPACE"
            android:textColor="#E5E5EA"
            android:textSize="9sp"
            android:textStyle="bold" />
            
        <TextView
            android:id="@+id/group_timestamp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Just Now"
            android:textColor="#8E8E93"
            android:textSize="8sp" />
    </LinearLayout>

    <!-- Icons Container -->
    <LinearLayout
        android:id="@+id/icon_container"
        android:layout_width="match_parent"
        android:layout_height="28dp"
        android:orientation="horizontal"
        android:layout_marginTop="6dp"
        android:gravity="center_vertical">
        <ImageView android:id="@+id/icon1" android:layout_width="20dp" android:layout_height="20dp" android:layout_marginEnd="-6dp" />
        <ImageView android:id="@+id/icon2" android:layout_width="20dp" android:layout_height="20dp" android:layout_marginEnd="-6dp" />
        <ImageView android:id="@+id/icon3" android:layout_width="20dp" android:layout_height="20dp" android:layout_marginEnd="-6dp" />
        <ImageView android:id="@+id/icon4" android:layout_width="20dp" android:layout_height="20dp" />
    </LinearLayout>

    <!-- Two Side-by-Side Restore Buttons (Constructed with RemoteViews-safe LinearLayout + ImageView + TextView for perfect layout compatibility!) -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="28dp"
        android:orientation="horizontal"
        android:layout_marginTop="8dp">
        
        <!-- Phone Button -->
        <LinearLayout
            android:id="@+id/restore_phone"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:layout_marginEnd="4dp"
            android:orientation="horizontal"
            android:gravity="center"
            android:background="@drawable/widget_button_blue"
            android:clickable="true"
            android:focusable="true">
            
            <ImageView
                android:layout_width="12dp"
                android:layout_height="12dp"
                android:src="@drawable/ic_phone_monochrome"
                android:layout_marginEnd="6dp"
                android:scaleType="fitCenter" />
                
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Phone"
                android:textColor="#E0E0E0"
                android:textSize="9sp"
                android:textStyle="bold" />
        </LinearLayout>

        <!-- External Button -->
        <LinearLayout
            android:id="@+id/restore_external"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:layout_marginStart="4dp"
            android:orientation="horizontal"
            android:gravity="center"
            android:background="@drawable/widget_button_indigo"
            android:clickable="true"
            android:focusable="true">
            
            <ImageView
                android:layout_width="12dp"
                android:layout_height="12dp"
                android:src="@drawable/ic_monitor_monochrome"
                android:layout_marginEnd="6dp"
                android:scaleType="fitCenter" />
                
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="External"
                android:textColor="#E0E0E0"
                android:textSize="9sp"
                android:textStyle="bold" />
        </LinearLayout>
    </LinearLayout>

</LinearLayout>
